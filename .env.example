# Project Claudia - Environment Configuration Guide
# Built by Anson (@ansonsaju)

# 1. LLM Provider (Mandatory)
# Claudia uses OpenAI models for the Adversarial Duel.
OPENAI_API_KEY=your_openai_api_key_here

# 2. Server Configuration
PORT=8001

# 3. Compliance Storage
# Audits are stored in the /audits directory with a 12-month retention policy.
AUDIT_LOG_PATH=./audits
