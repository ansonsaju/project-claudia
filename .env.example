# Project Claudia - Environment Configuration
# Copy this file to .env and fill in your keys

# --- LLM Providers ---
# Default providers: openai, anthropic, ollama, gemini
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3

# Builder Agent
BUILDER_PROVIDER=ollama
BUILDER_MODEL=llama3

# Hacker Agent
HACKER_PROVIDER=ollama
HACKER_MODEL=llama3

# Judge Agent (Arbiter)
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o

# --- API Keys ---
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here

# --- Ollama Config ---
OLLAMA_HOST=http://localhost:11434

# --- Operation Mode ---
# Set to true to disable Ollama fallback for cloud providers
CLAUDIA_STRICT_CLOUD=false

# Simulates random network failures for resilience testing (true/false)
CLAUDIA_SIMULATE_FAILURE=false
