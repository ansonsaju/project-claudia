# Project Claudia - Environment Configuration Guide
# Built by Anson (@ansonsaju)

# 1. Global Defaults
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# 2. Per-Agent Swarm Configuration (The Multi-Agent Flex)
# You can mix and match models for different roles.
BUILDER_PROVIDER=anthropic
BUILDER_MODEL=claude-3-5-sonnet

HACKER_PROVIDER=openai
HACKER_MODEL=gpt-4o

JUDGE_PROVIDER=gemini
JUDGE_MODEL=gemini-1.5-flash

# 3. Local Model Support (Ollama)
OLLAMA_ENDPOINT=http://localhost:11434

# 4. API Keys
OPENAI_API_KEY=your_sk_key_here
ANTHROPIC_API_KEY=your_sk_key_here
GEMINI_API_KEY=your_sk_key_here

# 5. Compliance & Logging
AUDIT_LOG_PATH=./audits
PORT=8001
